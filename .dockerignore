venv/
.venv/
__pycache__/
*.pyc
*.pyo
.git/
.gitignore
.idea/
.vscode/
.env
.env.*
!.env.example
epic.py
main.py
README.md
Dockerfile
docker-compose.yml
.dockerignore
# Frontend: Dockerfile's node stage builds these itself; shipping them blows up
# the build context (node_modules alone is ~100MB) and risks shadowing CI builds.
frontend/node_modules/
frontend/dist/
frontend/dist-remote/
# Vendored reference repos — not used in the image, but huge.
examples/
LOCAL_DEV.md
# Tests aren't run from the image; excluding keeps the layer small.
tests/
# Frontend dotenvs would otherwise enter the build context and be readable
# inside the build stage. Never copied into the final image, but Cloud Build
# uploads the whole context to Google before the build runs.
frontend/.env
frontend/.env.*
!frontend/.env.example

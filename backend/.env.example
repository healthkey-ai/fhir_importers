# ── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=dev-insecure-key-change-in-production
DEBUG=true
DATABASE_URL=postgres:///fhir_importers
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Identity / partner auth ───────────────────────────────────────────────
# Integrated mode (default): verify the host app's Firebase JWTs.
# Standalone mode: set PARTNER_AUTH_PROVIDERS= (empty) and use local logins.
PARTNER_AUTH_PROVIDERS=apps.accounts.providers.firebase.FirebaseTokenProvider
# For DEV, FIREBASE_PROJECT_ID alone is enough: the connector verifies host ID
# tokens against Google's public certs (verify-only mode, no SA key needed).
# Dev settings skip revocation checks automatically. For prod, provide
# FIREBASE_CREDENTIALS_JSON (service account) so revocation checks work.
FIREBASE_PROJECT_ID=healthtree-test
# FIREBASE_CREDENTIALS_JSON='{...service-account json...}'
# FIREBASE_SKIP_REVOCATION_CHECK=true   # auto-on in dev settings

# ── ctomop sync target (Phase 2; mirrors hk-labs) ─────────────────────────
CTOMOP_BASE_URL=http://localhost:9200
# CTOMOP_SYNC_URL defaults to ${CTOMOP_BASE_URL}/api/fhir/sync/
# OAuth2 patient/*.write bearer (service Identity issuer="urn:service")
CTOMOP_SERVICE_TOKEN=

# Fernet key (urlsafe-base64, 32 bytes) encrypting Epic tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# Empty in dev → derived from SECRET_KEY. REQUIRED in production.
TOKEN_ENCRYPTION_KEY=

# ── Epic / MyChart SMART-on-FHIR ──────────────────────────────────────────
# redirect_uri = the HOST (ht-phr) callback route, registered in the Epic app.
#   dev: http://localhost:5173/connect/mychart/callback
# The connector publishes its public signing keys at
#   GET /epic/.well-known/jwks.json
# Register THAT (your public connector URL + this path) as Epic's JWK Set URL,
# with EPIC_*_JWKS_KID matching the kid it serves.
EPIC_STAGING_ORG_ALIAS=my_chart_central
EPIC_STAGING_CLIENT_ID=
EPIC_STAGING_REDIRECT_URI=http://localhost:5173/connect/mychart/callback
EPIC_STAGING_PRIVATE_KEY_PATH=/path/to/epic_staging_private.key
EPIC_STAGING_JWKS_KID=epic-staging-1
EPIC_STAGING_SCOPES=openid fhirUser offline_access patient/*.read

EPIC_PROD_CLIENT_ID=
EPIC_PROD_REDIRECT_URI=http://localhost:5173/connect/mychart/callback
EPIC_PROD_PRIVATE_KEY_PATH=/path/to/epic_prod_private.key
EPIC_PROD_JWKS_KID=epic-prod-1
EPIC_PROD_SCOPES=openid offline_access patient/*.read

# EPIC_ORGANIZATIONS_FILE defaults to backend/apps/epic/organizations.json
EPIC_STATE_TTL_SECONDS=600
EPIC_HTTP_TIMEOUT_SECONDS=15

# ── Redis / Celery ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1

# Staging = Epic non-production / sandbox app. Used ONLY for the MyChart sandbox org.
STAGING_CLIENT_ID=d068e5ed-afa1-437f-86a4-412eff5888a6
STAGING_REDIRECT_URI=http://localhost:3001/redirections/epic
STAGING_PRIVATE_KEY_PATH=/path/to/epic_staging_private.key
STAGING_JWKS_KID=2025-08-01-rsa
STAGING_SCOPES=openid profile fhirUser

# Production = Epic production app. Used for all real organizations.
PROD_CLIENT_ID=
PROD_REDIRECT_URI=
PROD_PRIVATE_KEY_PATH=/path/to/epic_prod_private.key
PROD_JWKS_KID=
PROD_SCOPES=openid offline_access patient/*.read

ORGANIZATIONS_FILE=organizations.json
REDIS_URL=redis://localhost:6379/0
STATE_TTL_SECONDS=600

# Postgres for MyChart connections (compose overrides host to `postgres`).
DATABASE_URL=postgresql+asyncpg://fhir:fhir_dev_only@localhost:5432/fhir_importers

# Firebase ID token verification. For local dev with the Auth emulator:
FIREBASE_PROJECT_ID=demo-ht-phr
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Encrypts Epic tokens at rest. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Comma-separated origins allowed to call the API from a browser (host runs on :3001 locally).
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Docker-only: host port to publish the app on. Inside the container it always listens on 8000.
HOST_PORT=8030

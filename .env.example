# ── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=dev-insecure-key-change-in-production
DEBUG=true
DATABASE_URL=postgres:///fhir_importers
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Identity / partner auth ───────────────────────────────────────────────
# Integrated mode (default): verify the host app's Firebase JWTs.
# Standalone mode: set PARTNER_AUTH_PROVIDERS= (empty) and use local logins.
PARTNER_AUTH_PROVIDERS=apps.accounts.providers.firebase.FirebaseTokenProvider
# For DEV, FIREBASE_PROJECT_ID alone is enough: the connector verifies host ID
# tokens against Google's public certs (verify-only mode, no SA key needed).
# Dev settings skip revocation checks automatically. For prod, provide
# FIREBASE_CREDENTIALS_JSON (service account) so revocation checks work.
FIREBASE_PROJECT_ID=healthtree-test
# FIREBASE_CREDENTIALS_JSON='{...service-account json...}'
# FIREBASE_SKIP_REVOCATION_CHECK=true   # auto-on in dev settings

# ── ctomop sync target (wired in Phase 2; mirrors hk-labs) ────────────────
CTOMOP_BASE_URL=http://localhost:9200
# CTOMOP_SYNC_URL defaults to ${CTOMOP_BASE_URL}/api/fhir/sync/
CTOMOP_SERVICE_TOKEN=

# ── Epic / MyChart SMART-on-FHIR ──────────────────────────────────────────
EPIC_STAGING_ORG_ALIAS=my_chart_central
EPIC_STAGING_CLIENT_ID=d068e5ed-afa1-437f-86a4-412eff5888a6
EPIC_STAGING_REDIRECT_URI=http://localhost:3001/redirections/epic
EPIC_STAGING_PRIVATE_KEY_PATH=/path/to/epic_private.key
EPIC_STAGING_JWKS_KID=2025-08-01-rsa
EPIC_STAGING_SCOPES=openid profile fhirUser

EPIC_PROD_CLIENT_ID=
EPIC_PROD_REDIRECT_URI=http://localhost:3001/redirections/epic
EPIC_PROD_PRIVATE_KEY_PATH=/path/to/epic_private.key
EPIC_PROD_JWKS_KID=2025-08-01-rsa
EPIC_PROD_SCOPES=openid offline_access patient/*.read

# EPIC_ORGANIZATIONS_FILE defaults to backend/apps/epic/organizations.json
EPIC_STATE_TTL_SECONDS=600
EPIC_HTTP_TIMEOUT_SECONDS=15

# ── Redis / Celery ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
